    "stripe": "^17.0.0"
  },
  "peerDependencies": {
    "@mostajs/orm": "^1.8.0",
    "next": ">=14.0.0",
    "react": ">=18.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "better-sqlite3": "^12.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.7.0"
  }
